# Supabase — copy this file to .env.local and fill in your project's values.
# Find them in the Supabase dashboard: click "Connect" (top bar), or
# Project Settings > API Keys.
# Both are public (safe to expose in the browser); Row Level Security protects the data.

NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co

# Use the "publishable" key (sb_publishable_...). The legacy "anon" JWT key also
# works if you set NEXT_PUBLIC_SUPABASE_ANON_KEY instead.
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxxxxxxxxxxxxxxxxxxx
